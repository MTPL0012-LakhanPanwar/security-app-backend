{
  "info": {
    "name": "Security App Collection",
    "description": "Minimal Postman collection for the currently available public/admin enrollment APIs and health check.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "device_id",
      "value": "test-device-123",
      "type": "string"
    },
    {
      "key": "entry_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "exit_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Service Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/../health",
              "host": [
                "{{base_url}}",
                ".."
              ],
              "path": [
                "health"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Enrollments (User)",
      "item": [
        {
          "name": "Scan Entry (Lock Camera)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{entry_token}}\",\n  \"deviceId\": \"{{device_id}}\",\n  \"deviceInfo\": {\n    \"manufacturer\": \"Samsung\",\n    \"model\": \"Galaxy S21\",\n    \"osVersion\": \"Android 13\",\n    \"platform\": \"android\",\n    \"appVersion\": \"1.0.0\",\n    \"deviceName\": \"My Phone\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/enrollments/scan-entry",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "enrollments",
                "scan-entry"
              ]
            }
          }
        },
        {
          "name": "Scan Exit (Unlock Camera)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{exit_token}}\",\n  \"deviceId\": \"{{device_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/enrollments/scan-exit",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "enrollments",
                "scan-exit"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Enrollments (Admin)",
      "item": [
        {
          "name": "Force Exit (Forgot Exit Scan)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"enrollmentId\": \"<active_enrollment_id>\",\n  \"initiatedBy\": \"Admin Name\",\n  \"reason\": \"User forgot to scan exit\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/enrollments/admin/force-exit",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "enrollments",
                "admin",
                "force-exit"
              ]
            }
          },
          "description": "Protect this route with auth middleware when available."
        }
      ]
    }
  ]
}